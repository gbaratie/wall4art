# Database (local Docker or Neon)
DATABASE_URL=postgresql://wall4art:wall4art@localhost:5432/wall4art?schema=public

# API (change PORT if 3002 is already in use)
PORT=3002
NODE_ENV=development
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:5173

# Google OAuth (optional in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (optional in dev — uploads use base64 fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend (apps/web)
VITE_API_URL=
VITE_BASE_PATH=/
