{
  "name": "wall4art",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build": "pnpm run --filter @wall4art/shared build && pnpm run --filter @wall4art/api build && pnpm run --filter @wall4art/web build",
    "db:migrate": "pnpm --filter @wall4art/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @wall4art/api db:migrate:deploy",
    "db:seed": "pnpm --filter @wall4art/api db:seed",
    "db:studio": "pnpm --filter @wall4art/api db:studio",
    "lint": "pnpm run --parallel lint",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:install": "playwright install chromium --with-deps",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
